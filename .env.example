# Copy this file to .env.local for local development
# Set these as Environment Variables in your Vercel project settings

# Your 4-digit PIN to access the builder at /?builder=1
# Change this to something only you know before deploying
VITE_BUILDER_PIN=1234

# Your Formspree form ID (the part after formspree.io/f/)
# Create a free account at formspree.io, then paste your form ID here
# e.g. if your endpoint is https://formspree.io/f/xpwzjqkv, set: xpwzjqkv
# Leave blank to disable email notifications (approvals still work locally)
VITE_FORMSPREE_ID=
